{
  "name": "nexiq-cli",
  "version": "1.0.0",
  "description": "CLI for the nexiq React analysis server",
  "type": "module",
  "bin": {
    "nexiq": "dist/cli.js"
  },
  "main": "dist/cli.js",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@nexiq/cli": "workspace:*",
    "ink": "^4.4.1",
    "ink-spinner": "^5.0.0",
    "meow": "^13.2.0",
    "react": "^18.3.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.23",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
