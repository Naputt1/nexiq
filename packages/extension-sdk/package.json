{
  "name": "@nexiq/extension-sdk",
  "version": "1.0.3",
  "description": "SDK for creating nexiq extensions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Naputt1/nexiq.git",
    "directory": "packages/extension-sdk"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nexiq/shared": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@nexiq/shared": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "better-sqlite3": "^12.8.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
