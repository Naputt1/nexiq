{
  "name": "@nexiq/file-extension",
  "version": "1.0.0",
  "description": "Nexiq extension for file and package structure",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@nexiq/shared": "workspace:*",
    "@nexiq/extension-sdk": "workspace:*",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@nexiq/shared": "workspace:*",
    "@nexiq/extension-sdk": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
