{
  "name": "@nexiq/cli",
  "version": "1.0.1",
  "description": "Short and powerful React component dependency analysis",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "nodemon --watch src --ext ts --exec \"tsup src/index.ts --onSuccess 'node dist/index.js'\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@parcel/watcher": "^2.5.6",
    "@nexiq/extension-sdk": "workspace:*",
    "@nexiq/analyser": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.2",
    "@nexiq/shared": "workspace:*",
    "simple-git": "^3.30.0",
    "tmp": "^0.2.5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "@types/tmp": "^0.2.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "^4.0.18",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "nodemon": "^3.1.14",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.0.5"
  }
}
