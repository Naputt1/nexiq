{
  "name": "server",
  "version": "1.0.0",
  "description": "Shared backend for react-map",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "tsup src/index.ts --format esm --watch --dts",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@parcel/watcher": "^2.5.6",
    "@react-map/extension-sdk": "workspace:*",
    "analyser": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "shared": "workspace:*",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "3.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  }
}
