{
  "name": "@nexiq/cli",
  "version": "1.0.1",
  "description": "Short and powerful React component dependency analysis",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "dev": "nodemon --watch src --ext ts --exec \"tsup src/index.ts --onSuccess 'node dist/index.js'\"",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nexiq/analyser": "workspace:*",
    "@nexiq/extension-sdk": "workspace:*",
    "@nexiq/shared": "workspace:*",
    "@parcel/watcher": "^2.5.6",
    "better-sqlite3": "^12.8.0",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.2.5",
    "simple-git": "^3.33.0",
    "tmp": "^0.2.5",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/tmp": "^0.2.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-istanbul": "^4.1.2",
    "@vitest/coverage-v8": "4.1.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
