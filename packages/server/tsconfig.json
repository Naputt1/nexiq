{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "analyser": ["../analyser/src/index.ts"],
      "analyser/*": ["../analyser/src/*"],
      "@react-map/shared": ["../shared/src/index.ts"],
      "@react-map/shared/db": ["../shared/src/db/index.ts"],
      "@react-map/shared/*": ["../shared/src/*"],
      "@react-map/extension-sdk": ["../extension-sdk/src/index.ts"],
      "@react-map/extension-sdk/*": ["../extension-sdk/src/*"]
    }
  }
}
