{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@nexiq/analyser": ["../analyser/dist/index.ts"],
      "@nexiq/analyser/*": ["../analyser/dist/*"],
      "@nexiq/shared": ["../shared/dist/index.ts"],
      "@nexiq/shared/db": ["../shared/dist/db/index.ts"],
      "@nexiq/shared/*": ["../shared/dist/*"],
      "@nexiq/extension-sdk": ["../extension-sdk/dist/index.ts"],
      "@nexiq/extension-sdk/*": ["../extension-sdk/dist/*"]
    }
  }
}
