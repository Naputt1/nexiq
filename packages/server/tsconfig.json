{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@nexu/analyser": ["../analyser/src/index.ts"],
      "@nexu/analyser/*": ["../analyser/src/*"],
      "@nexu/shared": ["../shared/src/index.ts"],
      "@nexu/shared/db": ["../shared/src/db/index.ts"],
      "@nexu/shared/*": ["../shared/src/*"],
      "@nexu/extension-sdk": ["../extension-sdk/src/index.ts"],
      "@nexu/extension-sdk/*": ["../extension-sdk/src/*"]
    }
  }
}
