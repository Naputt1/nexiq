{
  "name": "@nexiq/component-extension",
  "type": "module",
  "version": "0.1.2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "*.node",
    "index.cjs"
  ],
  "scripts": {
    "build:rs": "napi build --platform --release",
    "postbuild:rs": "mv index.js index.cjs || true",
    "build:debug": "napi build --platform",
    "build:ts": "tsc",
    "build": "pnpm build:rs && pnpm build:ts",
    "test": "pnpm build && vitest run",
    "prepublishOnly": "napi prepublish -t npm",
    "artifacts": "napi artifacts",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "@nexiq/extension-sdk": "workspace:*",
    "@nexiq/shared": "workspace:*"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "typescript": "^5.7.3"
  }
}
