{
  "name": "analyser",
  "type": "module",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db/sqlite": {
      "types": "./dist/db/sqlite.d.ts",
      "import": "./dist/db/sqlite.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/analyzer.js ./sample-project ./out/graph.json\"",
    "start": "node dist/analyzer.js ./sample-project ./out/graph.json",
    "snapshot": "tsx src/snapshot.ts",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "@node-rs/xxhash": "^1.7.6",
    "better-sqlite3": "^12.6.2",
    "glob": "^11.0.3",
    "minimist": "^1.2.8",
    "seedrandom": "^3.0.5",
    "shared": "workspace:*"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/minimist": "^1.2.5",
    "@types/node": "^24.10.1",
    "@types/seedrandom": "^3.0.8",
    "@vitest/coverage-v8": "3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^3.2.4"
  }
}
