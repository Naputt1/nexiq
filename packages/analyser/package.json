{
  "name": "@nexiq/analyser",
  "type": "module",
  "version": "1.0.1",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./db/sqlite": {
      "types": "./dist/db/sqlite.d.ts",
      "import": "./dist/db/sqlite.js"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess \"node dist/analyzer.js ./sample-project ./out/graph.json\"",
    "start": "node dist/analyzer.js ./sample-project ./out/graph.json",
    "snapshot": "pnpm build && echo 'Build complete' && tsx src/snapshot.ts",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.18.3",
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@nexiq/shared": "workspace:*",
    "@node-rs/xxhash": "^1.7.6",
    "better-sqlite3": "^12.8.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "minimatch": "^10.0.0",
    "minimist": "^1.2.8",
    "seedrandom": "^3.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nexiq/extension-sdk": "workspace:*",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.5.0",
    "@types/seedrandom": "^3.0.8",
    "@vitest/coverage-v8": "4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
